{
  "name": "Strange Theme",
  "type": "dark",

  "colors": {
    "editor.background": "#1A1B1D",
    "editor.foreground": "#E8E0D4",
    "editorCursor.foreground": "#FFFFFF",
    "editor.selectionBackground": "#3579FF47",
    "editor.lineHighlightBackground": "#292c34",
    "editorLineNumber.foreground": "#979AA4",
    "editorLineNumber.activeForeground": "#E0E3EE",
    "editor.inactiveSelectionBackground": "#3A3D41",
    "editor.selectionHighlightBackground": "#ADD6FF26",
    "editor.findMatchHighlightBackground": "#DADDE552",
    "editor.hoverHighlightBackground": "#264f7840",
    "editorBracketMatch.background": "#D5D8E03D",
    "editorBracketMatch.border": "#C792EA",

    "editorIndentGuide.background": "#3A3D44",
    "editorIndentGuide.background1": "#3A3D44",
    "editorIndentGuide.activeBackground": "#FF5577",
    "editorIndentGuide.activeBackground1": "#FF5577",

    "editorBracketPairGuide.background1": "#C792EA80",
    "editorBracketPairGuide.background2": "#FFD70080",
    "editorBracketPairGuide.background3": "#82AAFF80",
    "editorBracketPairGuide.background4": "#FF994480",
    "editorBracketPairGuide.background5": "#82D99F80",
    "editorBracketPairGuide.background6": "#F48CCA80",
    "editorBracketPairGuide.activeBackground1": "#C792EA",
    "editorBracketPairGuide.activeBackground2": "#FFD700",
    "editorBracketPairGuide.activeBackground3": "#82AAFF",
    "editorBracketPairGuide.activeBackground4": "#FF9944",
    "editorBracketPairGuide.activeBackground5": "#82D99F",
    "editorBracketPairGuide.activeBackground6": "#F48CCA",

    "tab.activeBackground": "#E0E2F20d",
    "tab.activeBorderTop": "#FFFFFF",
    "tab.inactiveBackground": "#17191A",
    "tab.activeForeground": "#F5F9FE",
    "tab.inactiveForeground": "#9599A6",
    "sideBar.background": "#1A1B1D",
    "sideBarTitle.foreground": "#BBBBBB",
    "statusBar.background": "#0000",
    "activityBar.background": "#222427",
    "activityBar.foreground": "#F5F9FE",
    "activityBar.inactiveForeground": "#9599A6",
    "titleBar.activeBackground": "#222427",
    "titleBar.inactiveBackground": "#222427",
    "editorGroupHeader.tabsBackground": "#17191A",
    "editorGroupHeader.tabsBorder": "#E0E2F217",
    "list.activeSelectionBackground": "#E0E2F214",
    "list.inactiveSelectionBackground": "#E0E2F20d",
    "list.hoverBackground": "#E0E2F20d",

    "chat.requestBackground": "#222427",
    "chat.requestForeground": "#D1D3DB",
    "chat.responseBackground": "#1A1B1D",
    "chat.responseForeground": "#D1D3DB",
    "chat.slashCommandBackground": "#3579FF47",
    "chat.slashCommandForeground": "#82AAFF",

    "commandCenter.background": "#222427",
    "commandCenter.foreground": "#F5F9FE",
    "commandCenter.border": "#3A3D41",

    "quickInput.background": "#222427",
    "quickInput.foreground": "#D1D3DB",

    "welcomePage.background": "#1A1B1D"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#737780", "fontStyle": "italic" }
    },

    {
      "name": "Vue SFC <template> tag",
      "scope": [
        "entity.name.tag.template.html",
        "entity.name.tag.template.vue"
      ],
      "settings": { "foreground": "#F2858C", "fontStyle": "bold" }
    },
    {
      "name": "Vue SFC <script> tag",
      "scope": [
        "entity.name.tag.script.html",
        "entity.name.tag.script.vue"
      ],
      "settings": { "foreground": "#FFD700", "fontStyle": "bold" }
    },
    {
      "name": "Vue SFC <style> tag",
      "scope": [
        "entity.name.tag.style.html",
        "entity.name.tag.style.vue"
      ],
      "settings": { "foreground": "#21bd9e", "fontStyle": "bold" }
    },

    {
      "name": "Vue Directive Keywords: v-if v-for v-show v-model etc.",
      "scope": [
        "keyword.control.directive.vue",
        "keyword.control.conditional.vue",
        "keyword.control.loop.vue",
        "text.html.vue keyword.control.directive.vue",
        "text.html.vue keyword.control.conditional.vue",
        "text.html.vue keyword.control.loop.vue"
      ],
      "settings": { "foreground": "#FF5577", "fontStyle": "bold" }
    },
    {
      "name": "Vue Bind Shorthand Punctuation :",
      "scope": "punctuation.attribute-shorthand.bind.html.vue",
      "settings": { "foreground": "#C792EA", "fontStyle": "bold" }
    },
    {
      "name": "Vue Event Shorthand Punctuation @",
      "scope": "punctuation.attribute-shorthand.event.html.vue",
      "settings": { "foreground": "#FFD700", "fontStyle": "bold" }
    },
    {
      "name": "Vue Slot Shorthand Punctuation #",
      "scope": "punctuation.attribute-shorthand.slot.html.vue",
      "settings": { "foreground": "#82AAFF", "fontStyle": "bold" }
    },
    {
      "name": "Vue Directive Attribute Name (desctiption in :desctiption, click-left in @click-left)",
      "scope": [
        "entity.other.attribute-name.html.vue",
        "text.html.vue entity.other.attribute-name.html.vue"
      ],
      "settings": { "foreground": "#FF3366", "fontStyle": "bold" }
    },
    {
      "name": "Vue Directive Value Quotes",
      "scope": [
        "meta.attribute.directive.vue punctuation.definition.string.begin.html.vue",
        "meta.attribute.directive.vue punctuation.definition.string.end.html.vue",
        "text.html.vue punctuation.definition.string.begin.html.vue",
        "text.html.vue punctuation.definition.string.end.html.vue"
      ],
      "settings": { "foreground": "#0892dd", "fontStyle": "bold" }
    },
    {
      "name": "Vue Directive Expression Inside Values",
      "scope": [
        "source.ts.embedded.html.vue",
        "source.js.embedded.html.vue",
        "text.html.vue source.ts.embedded.html.vue",
        "text.html.vue source.js.embedded.html.vue"
      ],
      "settings": { "foreground": "#82D99F" }
    },

    {
      "name": "Vue Mustache Braces {{ }}",
      "scope": [
        "punctuation.definition.interpolation.begin.html.vue",
        "punctuation.definition.interpolation.end.html.vue",
        "punctuation.section.embedded.begin.vue",
        "punctuation.section.embedded.end.vue",
        "text.html.vue punctuation.definition.interpolation.begin.html.vue",
        "text.html.vue punctuation.definition.interpolation.end.html.vue"
      ],
      "settings": { "foreground": "#0892dd", "fontStyle": "bold" }
    },
    {
      "name": "Vue Mustache Expression Inside {{ }}",
      "scope": [
        "expression.embedded.vue",
        "text.html.vue expression.embedded.vue"
      ],
      "settings": { "foreground": "#0da860", "fontStyle": "bold" }
    },

    {
      "name": "HTML Tag Names",
      "scope": [
        "entity.name.tag.html",
        "entity.name.tag.vue",
        "text.html.vue entity.name.tag",
        "text.html.basic entity.name.tag"
      ],
      "settings": { "foreground": "#569CD6" }
    },
    {
      "name": "HTML Attribute Names (static)",
      "scope": [
        "entity.other.attribute-name.html",
        "text.html.vue entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": { "foreground": "#C896E0" }
    },
    {
      "name": "HTML Attribute Values (static)",
      "scope": [
        "meta.attribute-with-value.html string.quoted",
        "text.html.vue meta.attribute-with-value.html string.quoted"
      ],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "HTML Attribute Separator = sign",
      "scope": [
        "punctuation.separator.key-value.html",
        "punctuation.separator.key-value.vue"
      ],
      "settings": { "foreground": "#D5D8E0" }
    },
    {
      "name": "HTML Tag Punctuation <> </",
      "scope": [
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html"
      ],
      "settings": { "foreground": "#808080" }
    },

    {
      "name": "CSS Selector - Class Name",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.class.scss"
      ],
      "settings": { "foreground": "#FFB86C" }
    },
    {
      "name": "CSS Selector - ID",
      "scope": [
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.id.scss"
      ],
      "settings": { "foreground": "#FF9944" }
    },
    {
      "name": "CSS Selector - Tag Name",
      "scope": [
        "entity.name.tag.css",
        "entity.name.tag.scss",
        "entity.name.tag.less"
      ],
      "settings": { "foreground": "#569CD6" }
    },
    {
      "name": "CSS Selector - Pseudo-class",
      "scope": [
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-class.scss"
      ],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "CSS Selector - Pseudo-element",
      "scope": [
        "entity.other.attribute-name.pseudo-element.css",
        "entity.other.attribute-name.pseudo-element.scss"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "CSS Property Name",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss",
        "support.type.property-name.less"
      ],
      "settings": { "foreground": "#82D99F" }
    },
    {
      "name": "CSS Property Value Keyword",
      "scope": [
        "support.constant.property-value.css",
        "support.constant.property-value.scss"
      ],
      "settings": { "foreground": "#DCDCAA" }
    },
    {
      "name": "CSS String Value",
      "scope": [
        "string.quoted.css",
        "string.quoted.scss",
        "string.quoted.less"
      ],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "CSS Numeric Value",
      "scope": [
        "constant.numeric.css",
        "constant.numeric.scss",
        "constant.numeric.less"
      ],
      "settings": { "foreground": "#F48CCA" }
    },
    {
      "name": "CSS Unit (px em rem % etc)",
      "scope": [
        "keyword.other.unit.css",
        "keyword.other.unit.scss",
        "keyword.other.unit.less"
      ],
      "settings": { "foreground": "#F48CCA", "fontStyle": "italic" }
    },
    {
      "name": "CSS Variable --custom-prop",
      "scope": [
        "variable.css",
        "variable.scss",
        "variable.less",
        "variable.other.css",
        "variable.other.scss"
      ],
      "settings": { "foreground": "#FF5577" }
    },
    {
      "name": "CSS Function (rgb var calc etc)",
      "scope": [
        "support.function.css",
        "support.function.scss",
        "support.function.less"
      ],
      "settings": { "foreground": "#FFD700" }
    },
    {
      "name": "CSS !important Keyword",
      "scope": [
        "keyword.other.important.css",
        "keyword.other.important.scss"
      ],
      "settings": { "foreground": "#FF5577", "fontStyle": "bold" }
    },
    {
      "name": "CSS Attribute Selector [attr]",
      "scope": [
        "meta.attribute-selector.css",
        "meta.attribute-selector.scss"
      ],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "CSS Nesting Parent Selector & (SCSS/Less)",
      "scope": [
        "entity.other.attribute-name.parent-selector.css",
        "entity.other.attribute-name.parent-selector.scss",
        "keyword.operator.parent-selector.scss",
        "keyword.operator.parent-selector.less"
      ],
      "settings": { "foreground": "#FF9944", "fontStyle": "bold" }
    },
    {
      "name": "CSS Vendor Prefix Property",
      "scope": [
        "support.type.vendored.property-name.css",
        "support.type.vendored.property-name.scss"
      ],
      "settings": { "foreground": "#82D99F", "fontStyle": "italic" }
    },
    {
      "name": "SCSS/Less Nested Property",
      "scope": [
        "meta.property-name.scss",
        "meta.property-name.less"
      ],
      "settings": { "foreground": "#82D99F" }
    },
    {
      "name": "SCSS/Less Nested Selector inside &",
      "scope": [
        "meta.selector.scss meta.selector.scss",
        "meta.selector.less meta.selector.less"
      ],
      "settings": { "foreground": "#FFB86C" }
    },

    {
      "name": "JavaScript/TypeScript Storage Keywords",
      "scope": ["storage.type", "storage.modifier"],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "JavaScript/TypeScript Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop"
      ],
      "settings": { "foreground": "#C792EA" }
    },
    {
      "name": "JavaScript/TypeScript this super",
      "scope": [
        "variable.language.this",
        "variable.language.super",
        "variable.language"
      ],
      "settings": { "foreground": "#FF5577", "fontStyle": "bold" }
    },
    {
      "name": "JavaScript/TypeScript Boolean Null Undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language"
      ],
      "settings": { "foreground": "#FF9944" }
    },
    {
      "name": "JavaScript/TypeScript Numeric Constant",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#F48CCA" }
    },
    {
      "name": "JavaScript/TypeScript Template String",
      "scope": [
        "string.template",
        "string.template.js",
        "string.template.ts"
      ],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "JavaScript/TypeScript Template Expression ${}",
      "scope": [
        "template.expression",
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#82D99F" }
    },
    {
      "name": "JavaScript/TypeScript Escape Character",
      "scope": ["constant.character.escape"],
      "settings": { "foreground": "#FF9944", "fontStyle": "bold" }
    },
    {
      "name": "JavaScript/TypeScript Regexp",
      "scope": ["string.regexp"],
      "settings": { "foreground": "#F48CCA" }
    },
    {
      "name": "JavaScript/TypeScript Arrow Function =>",
      "scope": ["storage.type.function.arrow"],
      "settings": { "foreground": "#FF9944", "fontStyle": "bold" }
    },
    {
      "name": "JavaScript/TypeScript Decorator @",
      "scope": [
        "punctuation.decorator",
        "entity.name.decorator"
      ],
      "settings": { "foreground": "#FFD700" }
    },
    {
      "name": "JavaScript/TypeScript Object Key",
      "scope": [
        "meta.object-literal.key",
        "meta.object-literal.key.js",
        "meta.object-literal.key.ts"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "JavaScript/TypeScript Builtin Objects",
      "scope": [
        "support.type.object.console",
        "support.type.object.math",
        "support.type.object.json",
        "support.type.object.array",
        "support.type.object"
      ],
      "settings": { "foreground": "#82AAFF" }
    },

    {
      "name": "JSON Property Key",
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name.json.comments"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "JSON String Value",
      "scope": [
        "string.quoted.json",
        "string.quoted.json.comments"
      ],
      "settings": { "foreground": "#CE9178" }
    },

    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading.markdown",
        "entity.name.section.markdown"
      ],
      "settings": { "foreground": "#FF9944", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold.markdown"],
      "settings": { "foreground": "#FFB86C", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic.markdown"],
      "settings": { "foreground": "#82D99F", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code Inline",
      "scope": ["markup.inline.raw.markdown"],
      "settings": { "foreground": "#CE9178" }
    },
    {
      "name": "Markdown Code Block",
      "scope": ["markup.raw.block.markdown"],
      "settings": { "foreground": "#B5CEA8" }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": { "foreground": "#82AAFF" }
    },
    {
      "name": "Markdown List",
      "scope": ["markup.list.markdown"],
      "settings": { "foreground": "#C792EA" }
    },

    {
      "name": "Embedded CSS in <style> blocks",
      "scope": [
        "source.css.embedded.html",
        "source.css.embedded.vue",
        "meta.embedded.block.css",
        "text.html.vue source.css.embedded"
      ],
      "settings": { "foreground": "#B5CEA8" }
    },

    {
      "name": "Vue Attribute Separator = sign",
      "scope": [
        "meta.attribute.directive.vue punctuation.separator.key-value",
        "meta.attribute.bind.vue punctuation.separator.key-value",
        "meta.attribute.event.vue punctuation.separator.key-value"
      ],
      "settings": { "foreground": "#D5D8E0" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": { "foreground": "#FF9944", "bold": true },
    "function.declaration": { "foreground": "#FF9944", "bold": true },
    "function.defaultLibrary": { "foreground": "#FF9944", "bold": true },
    "method": { "foreground": "#FF9944", "bold": true },
    "method.declaration": { "foreground": "#FF9944", "bold": true },
    "variable": "#82AAFF",
    "variable.readonly": "#82AAFF",
    "variable.local": "#82AAFF",
    "variable.parameter": { "foreground": "#FFB86C", "italic": true },
    "parameter": { "foreground": "#FFB86C", "italic": true },
    "selfParameter": { "foreground": "#FF5577", "bold": true },
    "property": "#82D99F",
    "property.declaration": "#82D99F",
    "property.readonly": "#82D99F",
    "class": { "foreground": "#FFB86C", "bold": true },
    "class.declaration": { "foreground": "#FFB86C", "bold": true },
    "enum": "#82D99F",
    "enumMember": "#82D99F",
    "type": "#FFB86C",
    "type.declaration": "#FFB86C",
    "type.defaultLibrary": "#FFB86C",
    "interface": "#FFB86C",
    "namespace": "#C792EA",
    "keyword": "#C792EA",
    "string": "#82D99F",
    "number": "#F48CCA",
    "regexp": "#F48CCA",
    "operator": "#C792EA",
    "comment": "#737780",
    "comment.documentation": "#5A7A5A",
    "decorator": "#FFD700",
    "label": "#D5D8E0"
  }
}
